{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ContextPack",
  "type": "object",
  "required": [
    "context_pack_id",
    "question",
    "documents",
    "metadata"
  ],
  "properties": {
    "context_pack_id": {
      "type": "string",
      "minLength": 1
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "documents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "document_id",
          "title",
          "content",
          "source"
        ],
        "properties": {
          "document_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "page": {
            "type": [
              "string",
              "integer",
              "null"
            ]
          },
          "chunk_id": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
