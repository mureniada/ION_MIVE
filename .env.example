GEMINI_API_KEY=
OPENAI_API_KEY=

# Vector store (Qdrant only — ADR-005). In Docker Compose use http://qdrant:6333.
VECTOR_STORE_URL=http://localhost:6333
VECTOR_STORE_API_KEY=
VECTOR_COLLECTION=ion_corpus_v1
# Points per Qdrant upsert request (keeps payloads under Qdrant's ~32MB limit).
QDRANT_UPSERT_BATCH_SIZE=128

# Retrieval embeddings: local model => zero provider cost for retrieval.
EMBEDDING_BACKEND=local
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Runtime / backend ---
# DEBUG controls the SSE progress stream. true = expose SSE progress (developer mode);
# false = single final REST result only (live/user mode). Never enable DEBUG in a user-facing deployment.
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated origins allowed to call the API (the frontend origin).
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Frontend ---
# Base URL the frontend uses to reach the backend REST API.
FRONTEND_API_BASE_URL=http://localhost:8000

# --- Models: LOCKED Pair A (economical dev baseline), operator-approved 2026-07-13. ---
# Re-verify names + prices against official provider docs immediately before the first
# live call (M7). Prices are recorded in docs/MODEL_AND_PRICING_REGISTER.md and applied
# by app/modules/telemetry/pricing.py (pricing is configuration/data, never logic).
#   OpenAI gpt-5.4-mini            : input $0.75 / 1M, output $4.50 / 1M
#   Gemini gemini-3.1-flash-lite   : input $0.25 / 1M, output $1.50 / 1M
GEMINI_MODEL=gemini-3.1-flash-lite
OPENAI_MODEL=gpt-5.4-mini
